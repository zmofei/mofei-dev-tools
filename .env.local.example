# Optional GitHub OAuth Client ID for the GeoJSON Gist preview flow.
# This is safe to expose in browser code. The app has a public fallback.
NEXT_PUBLIC_GITHUB_CLIENT_ID=Ov23lis975wrIv1ap1Wy

# Optional Google Analytics Measurement ID.
# NEXT_PUBLIC_* values are inlined into the browser bundle at build time.
NEXT_PUBLIC_GA_ID=

# Mapbox public access token for the BBox map.
# This value is exposed to the browser by design; restrict allowed URLs in Mapbox.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional Search Console site verification token used in root metadata.
GOOGLE_SITE_VERIFICATION=
