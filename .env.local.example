# GitHub OAuth Configuration
# This is the Client ID for the GitHub OAuth App
# It's safe to expose this in client-side code
NEXT_PUBLIC_GITHUB_CLIENT_ID=Ov23lis975wrIv1ap1Wy

# Note: Client ID is NOT a secret and can be publicly visible
# Only Client Secret should be kept private (not used in this project)

# Google Analytics Measurement ID
# Set the real value in .env.local and the Cloudflare build environment.
NEXT_PUBLIC_GA_ID=

# Mapbox public access token for the BBox map.
# This value is exposed to the browser by design; restrict allowed URLs in Mapbox.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional Search Console site verification token.
GOOGLE_SITE_VERIFICATION=
