# Google Analytics 配置
# 在 Google Analytics 中创建新的属性后，将获得的 Measurement ID 填入下方
# 格式类似：G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Mapbox public access token for the BBox map.
# This is a browser-visible pk.* token; restrict allowed URLs in Mapbox.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional Search Console site verification token.
GOOGLE_SITE_VERIFICATION=

# 示例：
# NEXT_PUBLIC_GA_ID=G-1234567890
