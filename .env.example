# Optional Google Analytics Measurement ID.
# NEXT_PUBLIC_* values are inlined into the browser bundle at build time.
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Mapbox public access token for the BBox map.
# This is a browser-visible pk.* token; restrict allowed URLs in Mapbox.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional Search Console site verification token used in root metadata.
GOOGLE_SITE_VERIFICATION=

# Example:
# NEXT_PUBLIC_GA_ID=G-1234567890
